# Kraken Spot Autopilot — copy to .env and fill in values.
# Create a Kraken API key with trade permissions ONLY (no withdrawal).

# paper | live
BOT_MODE=paper

# Strategy: dca | grid | both
STRATEGY=dca

# Kraken credentials (leave empty in paper mode if you only need public market data)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Trading pair (ccxt unified symbol)
SYMBOL=BTC/USD

# --- DCA ---
DCA_QUOTE_AMOUNT=15
DCA_INTERVAL_SECONDS=86400
DCA_DIP_PCT=0
DCA_ENABLED=true

# --- Grid ---
GRID_ENABLED=false
GRID_LOWER_PRICE=0
GRID_UPPER_PRICE=0
GRID_LEVELS=8
GRID_QUOTE_PER_LEVEL=20
GRID_BASE_RESERVE=0

# --- Risk ---
MAX_DAILY_LOSS_QUOTE=50
MAX_POSITION_QUOTE=500
MAX_ORDER_QUOTE=50
KILL_SWITCH_FILE=data/KILL

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Runtime ---
POLL_INTERVAL_SECONDS=30
DATA_DIR=data
LOG_LEVEL=INFO
FEE_RATE=0.0026
